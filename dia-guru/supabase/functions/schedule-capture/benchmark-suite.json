{
  "meta": {
    "name": "schedule-capture-policy-benchmarks",
    "version": 2,
    "referenceTimezone": "America/Chicago",
    "notes": "Named policy scenarios for tuning rebalance, overlap, hard anchors, and fallback behavior.",
    "requiredSetup": [
      {
        "id": "dedicated-empty-benchmark-calendar",
        "status": "done",
        "instruction": "Live benchmark runs use the dedicated benchmark calendar configured through BENCHMARK_GOOGLE_CALENDAR_ID and BENCHMARK_SHARED_SECRET."
      },
      {
        "id": "benchmark-clear-hook",
        "status": "note",
        "instruction": "BENCHMARK_CLEAR_URL is optional. The runner can now clear benchmark days directly through Google Calendar when the hook is not configured."
      }
    ],
    "verificationGuide": {
      "criticalLiveScenarios": [
        {
          "id": "important-start-vs-flexible-chore",
          "why": "Regression for the original preemption bug: important exact-time work should be able to displace a weak flexible chore."
        },
        {
          "id": "generic-admin-should-not-displace-exercise",
          "why": "Guardrail: generic admin work should not displace a stronger workout commitment."
        }
      ],
      "isolatedPolicyTests": [
        "evaluatePreemptionNetGain allows important exact-time study work to preempt a weak chore",
        "evaluatePreemptionNetGain keeps generic admin from displacing exercise"
      ]
    }
  },
  "scenarios": [
    {
      "id": "important-start-vs-flexible-chore",
      "tags": [
        "must-pass",
        "preemption-regression"
